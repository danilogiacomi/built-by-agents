#!/bin/sh
# Keep README's "Built by agents" section in sync with this repo's local agent logs.
# Regenerates the section and re-stages README.md so each commit reflects the latest
# development footprint. No-op on machines without local logs (the script leaves the
# section untouched), so this is safe in CI and on fresh clones.
#
# Enabled via:  git config core.hooksPath .githooks

command -v bun >/dev/null 2>&1 || exit 0   # bun not installed → skip silently

bun run --silent scripts/usage-self.ts || exit 0       # never block a commit on this
git add README.md
exit 0
